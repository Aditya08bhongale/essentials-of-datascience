import pandas as pd
import numpy as np

# Load the Titanic dataset
data = pd.read_csv('Titanic-Dataset.csv')
data['FamilySize'] = data['SibSp'] + data['Parch']
data['IsAlone'] = np.where(data['FamilySize'] > 0, 0, 1)
data = pd.get_dummies(data, columns=['Embarked'], drop_first=True)

 #1. Calculate the survival rate by class
srg = data.groupby('Pclass')['Survived'].mean()
print(srg)
# 2. Calculate the survival rate by embarked location
e= data.groupby('Embarked_S')['Survived'].mean()
print(e)


# 3. Calculate the survival rate by family size
f = data.groupby('FamilySize')['Survived'].mean()
print(f)

# 4. Calculate the survival rate by being alone
k=data.groupby('IsAlone')['Survived'].mean()
print(k)

# 5. Get the average fare by class
l=data.groupby('Pclass')['Fare'].mean()
print(l)

# 6. Get the average age by class

h=data.groupby('Pclass')['Age'].mean()
print(h)
# 7. Get the average age by survival status
n=data.groupby('Survived')['Age'].mean()
print(n)

# 8. Get the average fare by survival status
m=data.groupby('Survived')['Fare'].mean()
print(m)


# 9. Get the number of survivors by class
number_of_survivors_by_class=data.groupby("Pclass")['Survived'].sum().sort_values(ascending=False)
number_of_survivors_by_class.index.name=None
number_of_survivors_by_class.name ='Pclass'
print(number_of_survivors_by_class)
# 10. Get the number of non-survivors by class
number_of_non_survivors_by_class =data.groupby('Pclass')['Survived'].apply(lambda x:(x==0).sum()).sort_values(ascending=False)
number_of_non_survivors_by_class.index.name = None
number_of_non_survivors_by_class.name='Pclass'
print(number_of_non_survivors_by_class)
